{
    "name": "jesuswasrasta/katasupermarket",
    "type": "project",
    "license": "GPL-3.0-or-later",
    "description": "KataSupermarket",
    "keywords": ["kata", "supermarket", "practice"],
    "require": {
        "php": "^8.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^12.2",
        "squizlabs/php_codesniffer": "^3.13",
        "phpstan/phpstan": "^2.1",
        "psalm/plugin-phpunit": "^0.19"
    },
    "authors": [
        {
            "name": "Ferdinando Santacroce",
            "email": "ferdinando.santacroce@gmail.com"
        }
    ],
    "minimum-stability": "stable",
    "prefer-stable": true,
    "config": {
        "bin-dir": "bin",
        "sort-packages": true,
        "optimize-autoloader": true
    },
    "autoload": {
        "psr-4": {
            "KataSupermarket\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "KataSupermarket\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "phpcs": "phpcs src tests --standard=PSR12",
        "phpstan": "phpstan analyse src tests",
        "check": [
            "@phpcs",
            "@phpstan",
            "@test"
        ]
    }
}
