{
	"customizations": {
		"vscode": {
			"extensions": [
				// Cursor-Specific: AI Pair Programming
				"GitHub.copilot",
				"GitHub.copilot-chat"
			],

			"settings": {
				// Cursor AI Settings
				"github.copilot.enable": {
					"*": true,
					"php": true,
					"markdown": true
				},
				"github.copilot.editor.enableAutoCompletions": true,

				// Editor Settings (optimized for Cursor AI)
				"editor.suggestSelection": "first",
				"editor.quickSuggestions": {
					"other": true,
					"comments": true,
					"strings": true
				},

				// Inline AI suggestions
				"editor.inlineSuggest.enabled": true
			}
		}
	}
}
