{
	"launch": {
		"version": "0.2.0",
		"configurations": [
			{
				"name": "Listen for Xdebug",
				"type": "php",
				"request": "launch",
				"port": 9003,
				"pathMappings": {
					"/workspace": "${workspaceFolder}"
				},
				"log": false,
				"xdebugSettings": {
					"max_data": 65535,
					"show_hidden": 1,
					"max_children": 100,
					"max_depth": 5
				}
			},
			{
				"name": "Launch currently open script",
				"type": "php",
				"request": "launch",
				"program": "${file}",
				"cwd": "${fileDirname}",
				"port": 9003,
				"pathMappings": {
					"/workspace": "${workspaceFolder}"
				}
			},
			{
				"name": "PHPUnit Current File",
				"type": "php",
				"request": "launch",
				"program": "${workspaceFolder}/vendor/bin/phpunit",
				"args": [
					"${file}"
				],
				"cwd": "${workspaceFolder}",
				"port": 9003,
				"pathMappings": {
					"/workspace": "${workspaceFolder}"
				},
				"env": {
					"XDEBUG_MODE": "debug,coverage"
				}
			},
			{
				"name": "PHPUnit All Tests",
				"type": "php",
				"request": "launch",
				"program": "${workspaceFolder}/vendor/bin/phpunit",
				"args": [
					"--testdox"
				],
				"cwd": "${workspaceFolder}",
				"port": 9003,
				"pathMappings": {
					"/workspace": "${workspaceFolder}"
				},
				"env": {
					"XDEBUG_MODE": "debug,coverage"
				}
			}
		]
	},
	"tasks": {
		"version": "2.0.0",
		"tasks": [
			{
				"label": "Run Tests",
				"type": "shell",
				"command": "composer test",
				"group": {
					"kind": "test",
					"isDefault": true
				},
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			},
			{
				"label": "Run Tests with Coverage",
				"type": "shell",
				"command": "XDEBUG_MODE=coverage vendor/bin/phpunit --coverage-text",
				"group": "test",
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			},
			{
				"label": "Check Code Style",
				"type": "shell",
				"command": "composer phpcs",
				"group": "build",
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			},
			{
				"label": "Fix Code Style",
				"type": "shell",
				"command": "vendor/bin/phpcbf src/ tests/",
				"group": "build",
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			},
			{
				"label": "Run PHPStan",
				"type": "shell",
				"command": "composer phpstan",
				"group": "build",
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			},
			{
				"label": "Run All Checks",
				"type": "shell",
				"command": "composer check",
				"group": {
					"kind": "build",
					"isDefault": true
				},
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			},
			{
				"label": "Install Dependencies",
				"type": "shell",
				"command": "composer install",
				"group": "build",
				"presentation": {
					"reveal": "always",
					"panel": "new"
				},
				"problemMatcher": []
			}
		]
	}
}
