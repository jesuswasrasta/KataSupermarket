{
	"name": "KataSupermarket PHP",

	// Use official PHP image with XDebug (Debian 13 Trixie)
	"image": "mcr.microsoft.com/devcontainers/php:8.3-trixie",

	// Mount the workspace folder
	"workspaceMount": "source=${localWorkspaceFolder},target=/workspace,type=bind",
	"workspaceFolder": "/workspace",

	// Enable Docker-in-Docker for projects that need Docker support
	"features": {
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"moby": true,
			"azureDnsAutoDetection": true,
			"installDockerBuildx": true,
			"version": "latest",
			"dockerDashComposeVersion": "v2"
		}
	},

	// Configure tool-specific properties
	"customizations": {
		"vscode": {
			"extensions": [
				// PHP Extensions
				"bmewburn.vscode-intelephense-client",
				"xdebug.php-debug",

				// Code Quality
				"wongjn.php-sniffer",
				"sanderronde.phpstan-vscode",

				// Testing
				"recca0120.vscode-phpunit",

				// Git
				"eamodio.gitlens",

				// General Development
				"EditorConfig.EditorConfig"
			],

			"settings": {
				// PHP Settings
				"php.validate.executablePath": "/usr/local/bin/php",
				"php.suggest.basic": false,

				// Intelephense
				"intelephense.telemetry.enabled": false,

				// PHP Sniffer (Code Sniffer & Beautifier)
				"phpSniffer.standard": "PSR12",
				"phpSniffer.executablesFolder": "${workspaceFolder}/vendor/bin/",
				"phpSniffer.autoDetect": true,

				// PHPStan
				"phpstan.enabled": true,
				"phpstan.path": "${workspaceFolder}/vendor/bin/phpstan",
				"phpstan.level": "max",

				// PHPUnit
				"phpunit.php": "/usr/local/bin/php",
				"phpunit.phpunit": "${workspaceFolder}/vendor/bin/phpunit",
				"phpunit.args": ["--colors=always"],
				"phpunit.clearOutputOnRun": true,

				// Editor Settings
				"editor.formatOnSave": false,
				"editor.tabSize": 4,
				"editor.insertSpaces": true,
				"editor.rulers": [120],

				// Files
				"files.eol": "\n",
				"files.insertFinalNewline": true,
				"files.trimTrailingWhitespace": true
			}
		}
	},

	// Forward Xdebug port
	"forwardPorts": [9003],

	// Install project dependencies (Xdebug already included in Trixie image)
	"postCreateCommand": "composer install",

	// Configure Xdebug for debugging and coverage (update existing xdebug.ini)
	"postStartCommand": "sudo sed -i 's/xdebug.mode = debug/xdebug.mode = debug,coverage/' /usr/local/etc/php/conf.d/xdebug.ini && sudo sed -i 's/xdebug.client_port = 9000/xdebug.client_port = 9003/' /usr/local/etc/php/conf.d/xdebug.ini && echo 'xdebug.client_host = host.docker.internal' | sudo tee -a /usr/local/etc/php/conf.d/xdebug.ini > /dev/null",

	// Use non-root user
	"remoteUser": "vscode"
}
