{
	"name": "KataSupermarket PHP",

	// Use official PHP image with Xdebug pre-installed
	"image": "mcr.microsoft.com/devcontainers/php:8.3-bookworm",

	"workspaceFolder": "/workspaces/${localWorkspaceFolderBasename}",

	// Configure tool-specific properties
	"customizations": {
		"vscode": {
			"extensions": [
				// PHP Extensions
				"bmewburn.vscode-intelephense-client",
				"xdebug.php-debug",

				// Code Quality
				"ikappas.phpcs",
				"sanderronde.phpstan-vscode",

				// Testing
				"recca0120.vscode-phpunit",

				// Git
				"eamodio.gitlens",

				// General Development
				"EditorConfig.EditorConfig"
			],

			"settings": {
				// PHP Settings
				"php.validate.executablePath": "/usr/local/bin/php",
				"php.suggest.basic": false,

				// Intelephense
				"intelephense.telemetry.enabled": false,

				// PHP CS (Code Sniffer)
				"phpcs.enable": true,
				"phpcs.standard": "PSR12",
				"phpcs.executablePath": "${workspaceFolder}/vendor/bin/phpcs",

				// PHPStan
				"phpstan.enabled": true,
				"phpstan.path": "${workspaceFolder}/vendor/bin/phpstan",
				"phpstan.level": "max",

				// PHPUnit
				"phpunit.php": "/usr/local/bin/php",
				"phpunit.phpunit": "${workspaceFolder}/vendor/bin/phpunit",
				"phpunit.args": ["--colors=always"],
				"phpunit.clearOutputOnRun": true,

				// Editor Settings
				"editor.formatOnSave": false,
				"editor.tabSize": 4,
				"editor.insertSpaces": true,
				"editor.rulers": [120],

				// Files
				"files.eol": "\n",
				"files.insertFinalNewline": true,
				"files.trimTrailingWhitespace": true
			}
		}
	},

	// Forward Xdebug port
	"forwardPorts": [9003],

	// Install Xdebug and project dependencies
	"postCreateCommand": "pecl install xdebug && docker-php-ext-enable xdebug && composer install",

	// Configure Xdebug
	"postStartCommand": "echo 'xdebug.mode=debug,coverage\nxdebug.start_with_request=yes\nxdebug.client_port=9003' > /usr/local/etc/php/conf.d/xdebug.ini",

	// Use non-root user
	"remoteUser": "vscode"
}
